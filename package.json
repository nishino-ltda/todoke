{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "vitest --mode test",
        "test:watch": "vitest watch --mode test",
        "test:coverage": "vitest run --coverage --mode test",
        "test:e2e": "cypress open",
        "test:e2e:ci": "concurrently -k \"php artisan serve\" \"cypress run\"",
        "test:e2e:local": "concurrently -k \"php artisan serve\" \"cypress open\""
    },
    "devDependencies": {
        "@pinia/testing": "^1.0.1",
        "@types/node": "^22.15.11",
        "@vitejs/plugin-vue": "^5.2.3",
        "@vitest/coverage-v8": "^1.6.0",
        "@vitest/expect": "^3.1.3",
        "@vue/test-utils": "^2.4.6",
        "axios": "^1.8.2",
        "concurrently": "^9.0.1",
        "cypress": "^14.3.2",
        "happy-dom": "^16.0.1",
        "laravel-vite-plugin": "^1.2.0",
        "vite": "^6.2.4",
        "vitest": "^1.3.1",
        "vue": "^3.5.13"
    },
    "dependencies": {
        "@mdi/font": "^7.4.47",
        "pinia": "^3.0.2",
        "vue-router": "^4.5.1",
        "vuetify": "^3.8.3"
    }
}
